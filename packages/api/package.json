{
	"name": "@forge-ts/api",
	"version": "0.6.3",
	"type": "module",
	"description": "OpenAPI spec and API reference generator for forge-ts",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/kryptobaseddev/forge-ts"
	},
	"publishConfig": {
		"access": "public"
	},
	"files": [
		"dist",
		"README.md"
	],
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		}
	},
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"test": "vitest run",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@forge-ts/core": "workspace:*"
	},
	"devDependencies": {
		"tsup": "^8.3.5",
		"typescript": "^5.8.2",
		"vitest": "^4.1.0"
	}
}
