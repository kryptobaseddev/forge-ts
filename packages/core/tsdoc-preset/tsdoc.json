{
	"$schema": "https://developer.microsoft.com/json-schemas/tsdoc/v0/tsdoc.schema.json",
	"noStandardTags": false,
	"tagDefinitions": [
		{ "tagName": "@route", "syntaxKind": "block" },
		{ "tagName": "@category", "syntaxKind": "block" },
		{ "tagName": "@since", "syntaxKind": "block" },
		{ "tagName": "@guide", "syntaxKind": "block" },
		{ "tagName": "@concept", "syntaxKind": "block" },
		{ "tagName": "@response", "syntaxKind": "block" },
		{ "tagName": "@query", "syntaxKind": "block" },
		{ "tagName": "@header", "syntaxKind": "block" },
		{ "tagName": "@body", "syntaxKind": "block" },
		{ "tagName": "@quickstart", "syntaxKind": "modifier" },
		{ "tagName": "@faq", "syntaxKind": "block" },
		{ "tagName": "@breaking", "syntaxKind": "block" },
		{ "tagName": "@migration", "syntaxKind": "block" },
		{ "tagName": "@complexity", "syntaxKind": "block" }
	],
	"supportForTags": {
		"@alpha": true,
		"@beta": true,
		"@decorator": true,
		"@defaultValue": true,
		"@deprecated": true,
		"@eventProperty": true,
		"@example": true,
		"@inheritDoc": true,
		"@internal": true,
		"@label": true,
		"@link": true,
		"@override": true,
		"@packageDocumentation": true,
		"@param": true,
		"@privateRemarks": true,
		"@public": true,
		"@readonly": true,
		"@remarks": true,
		"@returns": true,
		"@sealed": true,
		"@see": true,
		"@throws": true,
		"@typeParam": true,
		"@virtual": true,
		"@route": true,
		"@category": true,
		"@since": true,
		"@guide": true,
		"@concept": true,
		"@response": true,
		"@query": true,
		"@header": true,
		"@body": true,
		"@quickstart": true,
		"@faq": true,
		"@breaking": true,
		"@migration": true,
		"@complexity": true
	}
}
