3e:["$","p",null,{"children":["Runs the TSDoc enforcement pass against a project.  The enforcer walks all exported symbols that meet the configured minimum visibility threshold and emits diagnostics for any documentation deficiencies it finds.  ### Error codes | Code | Severity | Condition | |------|----------|-----------| | E001 | error    | Exported symbol is missing a TSDoc summary. | | E002 | error    | Function/method parameter lacks a ",["$","code",null,{"children":"@param"}]," tag. | | E003 | error    | Non-void function/method lacks a ",["$","code",null,{"children":"@returns"}]," tag. | | E004 | error    | Exported function/method is missing an ",["$","code",null,{"children":"@example"}]," block. | | E005 | error    | Package entry point (index.ts) is missing ",["$","code",null,{"children":"@packageDocumentation"}],". | | E006 | error    | Public/protected class member is missing a TSDoc comment. | | E007 | error    | Interface/type alias property is missing a TSDoc comment. | | W001 | warning  | TSDoc comment contains parse errors. | | W002 | warning  | Function body throws but has no ",["$","code",null,{"children":"@throws"}]," tag. | | W003 | warning  | ",["$","code",null,{"children":"@deprecated"}]," tag is present without explanation. | | W006 | warning  | TSDoc parser-level syntax error (invalid tag, malformed block, etc.). | | E009 | error    | tsconfig.json required strict-mode flag is missing or disabled (guard). | | E010 | error    | Config drift: a rule severity is weaker than the locked value. | | E013 | error    | Exported function/class is missing a ",["$","code",null,{"children":"@remarks"}]," block. | | E014 | warn     | Optional property of interface/type is missing ",["$","code",null,{"children":"@defaultValue"}],". | | E015 | error    | Generic symbol is missing ",["$","code",null,{"children":"@typeParam"}]," for a type parameter. | | W005 | warn     | Symbol references other symbols via ",["$","code",null,{"children":"{@link}"}]," but has no ",["$","code",null,{"children":"@see"}]," tags. | | W007 | warn     | Guide FORGE:AUTO section references a symbol that no longer exists. | | W008 | warn     | Exported public symbol is not mentioned in any guide page. | | E017 | error    | ",["$","code",null,{"children":"@internal"}]," symbol re-exported through public barrel (index.ts). | | E018 | warn     | ",["$","code",null,{"children":"@route"}],"-tagged function missing ",["$","code",null,{"children":"@response"}]," tag. | | W009 | warn     | ",["$","code",null,{"children":"{@inheritDoc}"}]," references a symbol that does not exist. | | W010 | warn     | ",["$","code",null,{"children":"@breaking"}]," tag present without ",["$","code",null,{"children":"@migration"}]," path. | | W011 | warn     | New public export missing ",["$","code",null,{"children":"@since"}]," version tag. | | E019 | error    | Non-test file contains ",["$","code",null,{"children":"@ts-expect-error"}]," / ",["$","code",null,{"children":"@ts-expect-error"}],". | | E020 | error    | Exported symbol has ",["$","code",null,{"children":"any"}]," in its public API signature. | | W012 | warn     | ",["$","code",null,{"children":"{@link}"}]," display text appears stale relative to target summary. | | W013 | warn     | ",["$","code",null,{"children":"@example"}]," block may be stale (arg count mismatch). |  When ",["$","code",null,{"children":"config.enforce.strict"}]," is ",["$","code",null,{"children":"true"}]," all warnings are promoted to errors."]}]
