{
	"name": "@codluv/forge-core",
	"version": "0.1.0",
	"type": "module",
	"description": "Shared types, interfaces, and core AST walker for forge-ts",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/codluv/forge-ts"
	},
	"publishConfig": {
		"access": "public"
	},
	"files": [
		"dist",
		"README.md"
	],
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		}
	},
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@microsoft/tsdoc": "^0.15.1",
		"typescript": "^5.8.2"
	},
	"devDependencies": {
		"@codluv/forge-api": "workspace:*",
		"@codluv/forge-enforcer": "workspace:*",
		"@codluv/forge-gen": "workspace:*",
		"tsup": "^8.3.5"
	}
}
