{
	"name": "@forge-ts/gen",
	"version": "0.12.0",
	"type": "module",
	"description": "Markdown/MDX and llms.txt generator for forge-ts",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/kryptobaseddev/forge-ts"
	},
	"publishConfig": {
		"access": "public"
	},
	"files": [
		"dist",
		"README.md"
	],
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		}
	},
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@forge-ts/core": "workspace:*",
		"gray-matter": "^4.0.3",
		"remark-frontmatter": "^5.0.0",
		"remark-gfm": "^4.0.1",
		"remark-mdx": "^3.1.1",
		"remark-parse": "^11.0.0",
		"remark-stringify": "^11.0.0",
		"unified": "^11.0.5",
		"unist-util-visit": "^5.1.0"
	},
	"devDependencies": {
		"tsup": "^8.3.5",
		"typescript": "^5.8.2"
	}
}
