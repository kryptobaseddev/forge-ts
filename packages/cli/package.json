{
	"name": "@codluv/forge-cli",
	"version": "0.1.0",
	"type": "module",
	"description": "CLI entry point for forge-ts",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/codluv/forge-ts"
	},
	"publishConfig": {
		"access": "public"
	},
	"files": [
		"dist",
		"README.md"
	],
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"bin": {
		"forge-ts": "./dist/index.js"
	},
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		}
	},
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@cleocode/lafs-protocol": "^1.7.0",
		"@codluv/forge-api": "workspace:*",
		"@codluv/forge-core": "workspace:*",
		"@codluv/forge-doctest": "workspace:*",
		"@codluv/forge-enforcer": "workspace:*",
		"@codluv/forge-gen": "workspace:*",
		"citty": "^0.2.1"
	},
	"devDependencies": {
		"tsup": "^8.3.5",
		"typescript": "^5.8.2"
	}
}
