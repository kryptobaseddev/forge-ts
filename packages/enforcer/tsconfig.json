{
	"extends": "../../tsconfig.json",
	"compilerOptions": {
		"outDir": "dist",
		"rootDir": "src",
		"strict": true,
		"strictNullChecks": true,
		"noImplicitAny": true,
		"composite": false,
		"incremental": false,
		"tsBuildInfoFile": "dist/.tsbuildinfo"
	},
	"include": ["src/**/*"],
	"exclude": ["node_modules", "dist", "**/*.test.ts", "**/*.spec.ts"]
}
