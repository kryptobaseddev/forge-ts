{
	"compilerOptions": {
		"target": "ESNext",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"lib": ["ESNext"],
		"types": ["node"],
		"strict": true,
		"verbatimModuleSyntax": true,
		"declaration": true,
		"declarationMap": true,
		"sourceMap": true,
		"composite": true,
		"incremental": true,
		"skipLibCheck": true,
		"outDir": "dist",
		"rootDir": ".",
		"paths": {
			"@codluv/forge-core": ["./packages/core/dist/index.d.ts"],
			"@codluv/forge-enforcer": ["./packages/enforcer/dist/index.d.ts"],
			"@codluv/forge-doctest": ["./packages/doctest/dist/index.d.ts"],
			"@codluv/forge-api": ["./packages/api/dist/index.d.ts"],
			"@codluv/forge-gen": ["./packages/gen/dist/index.d.ts"],
			"@codluv/forge-cli": ["./packages/cli/dist/index.d.ts"]
		}
	},
	"references": [
		{ "path": "./packages/core" },
		{ "path": "./packages/enforcer" },
		{ "path": "./packages/doctest" },
		{ "path": "./packages/api" },
		{ "path": "./packages/gen" },
		{ "path": "./packages/cli" }
	],
	"exclude": ["node_modules", "packages/*/dist", "packages/*/node_modules"]
}
