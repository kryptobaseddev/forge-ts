{
	"name": "forge-ts",
	"version": "0.22.0",
	"description": "Universal TypeScript documentation compiler — enforces TSDoc as a build gate, then generates all artifacts from source in one pass",
	"repository": {
		"type": "git",
		"url": "https://github.com/kryptobaseddev/forge-ts"
	},
	"private": true,
	"type": "module",
	"engines": {
		"node": ">=24.0.0"
	},
	"packageManager": "pnpm@10.32.1",
	"scripts": {
		"build": "pnpm --filter @forge-ts/core build && pnpm --filter '!@forge-ts/core' -r build",
		"test": "vitest run --config vitest.config.ts",
		"check": "pnpm build",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write .",
		"clean": "pnpm -r exec -- rm -rf dist .cache *.tsbuildinfo",
		"changeset": "changeset",
		"cs:version": "changeset version",
		"release": "pnpm build && changeset publish",
		"prerelease": "pnpm build && pnpm test",
		"forge:check": "forge-ts check --cwd packages/core",
		"forge:build": "forge-ts build",
		"forge:test": "forge-ts test --cwd packages/core",
		"docs:generate": "pnpm build && node packages/cli/dist/index.js build",
		"sync:tsdoc-spec": "tsx scripts/sync-tsdoc-spec.ts",
		"prepare": "husky",
		"vg:check": "versionguard check",
		"vg:validate": "versionguard validate"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.9",
		"@changesets/changelog-github": "^0.6.0",
		"@changesets/cli": "^2.30.0",
		"@cleocode/lafs": "^2026.3.74",
		"@codluv/versionguard": "^0.4.0",
		"@forge-ts/cli": "^0.19.4",
		"@microsoft/tsdoc": "^0.16.0",
		"@types/node": "^25.5.0",
		"husky": "^9.1.7",
		"tsup": "^8.5.0",
		"typescript": "6.0.2",
		"vite": "^8.0.3",
		"vitest": "^4.1.1"
	}
}
