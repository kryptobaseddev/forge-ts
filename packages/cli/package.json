{
	"name": "@forge-ts/cli",
	"version": "0.20.0",
	"type": "module",
	"description": "CLI entry point for forge-ts",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/kryptobaseddev/forge-ts"
	},
	"publishConfig": {
		"access": "public"
	},
	"files": [
		"dist",
		"README.md"
	],
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"bin": {
		"forge-ts": "./dist/index.js"
	},
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		}
	},
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@cleocode/lafs": "^2026.3.74",
		"@forge-ts/api": "workspace:*",
		"@forge-ts/core": "workspace:*",
		"@forge-ts/doctest": "workspace:*",
		"@forge-ts/enforcer": "workspace:*",
		"@forge-ts/gen": "workspace:*",
		"citty": "^0.2.1",
		"consola": "^3.4.2"
	},
	"devDependencies": {
		"tsup": "^8.3.5",
		"typescript": "^6.0.2"
	}
}
